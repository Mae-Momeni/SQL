# Custom cross-validation indices (example if pre-defined)
cv_indices <- indexes  # Ensure `indexes` contains the indices for training rows per fold

# Extract validation rows for each fold
oof_valid_predictions <- mod_prob_auto_indemnity$pred %>%
  rowwise() %>%
  filter(!rowIndex %in% cv_indices[[Resample]]) %>%  # Exclude training rows
  ungroup() %>%
  distinct(rowIndex, .keep_all = TRUE)  # Remove duplicates

# Verify validation set sizes per fold
valid_set_summary <- oof_valid_predictions %>%
  group_by(Resample) %>%
  summarise(valid_set_size = n())

# Print validation set summary
print(valid_set_summary)