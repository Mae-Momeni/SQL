library(dplyr)
library(purrr)

# Step 1: Extract custom training indices from the model
cv_indices <- indexes  # Assuming indexes is your list of training indices for each fold

# Step 2: Identify validation rows for each Resample
oof_valid_predictions <- mod_prob_auto_indemnity$pred %>%
  filter(map_lgl(Resample, ~ !rowIndex %in% cv_indices[[.x]])) %>%  # Keep only validation rows
  distinct(rowIndex, Resample, .keep_all = TRUE)  # Remove duplicates

# Step 3: Verify validation set sizes
valid_set_summary <- oof_valid_predictions %>%
  group_by(Resample) %>%
  summarise(valid_set_size = n_distinct(rowIndex))

# Step 4: Print outputs
print(valid_set_summary)  # Validation set sizes per fold
print(oof_valid_predictions)  # Final validation rows