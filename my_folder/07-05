library(dplyr)
library(lubridate)  # for easier date manipulation

# Convert DATEOFBIRTH_CLMT to a Date format if it's not already
data_to_test <- data_to_test %>%
  mutate(DATEOFBIRTH_CLMT = as.Date(DATEOFBIRTH_CLMT, format = "%Y-%m-%d"))

# Now calculate age using the correct date format
data_to_test <- data_to_test %>%
  mutate(age = lossyear - year(DATEOFBIRTH_CLMT))