# Join oof_pred_sev_valid column from data_train_sev
final_data <- data_train_prob %>%
  left_join(data_train_sev %>% select(rownum, oof_pred_sev_valid), by = "rownum") %>%
  mutate(
    # Fill missing oof_pred_sev_valid values with pred_sev from data_train_prob_no_payment
    oof_pred_sev_valid = ifelse(
      is.na(oof_pred_sev_valid),
      data_train_prob_no_payment %>%
        filter(rownum %in% rownum) %>%
        pull(pred_sev),
      oof_pred_sev_valid
    )
  )

