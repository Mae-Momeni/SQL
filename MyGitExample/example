library(dplyr)

# Extract validation rows: Keep only rows where their Resample column matches the fold
valid_set_predictions <- mod_prob_auto_indemnity$pred %>%
  filter(Resample == paste0("Resample", ceiling(rowIndex / (nrow(data_train) / cv_number)))) %>%
  distinct(rowIndex, .keep_all = TRUE) %>%  # Deduplicate for safety
  ungroup()

# Verify validation set sizes
valid_set_summary <- valid_set_predictions %>%
  group_by(Resample) %>%
  summarise(valid_set_size = n())

# Display validation set sizes
print(valid_set_summary)