initialize <- function(config_file, model_name) {
  # Load the configuration file
  self$config <- yaml::read_yaml(config_file)
  
  # Check if the model name exists in the config
  if (!model_name %in% names(self$config$modeling)) {
    stop(glue::glue("Model '{model_name}' not found in the configuration file."))
  }
  
  # Load model-specific settings
  self$model <- self$config$modeling[[model_name]]
  
  message(glue::glue("Model '{model_name}' initialized successfully."))
}