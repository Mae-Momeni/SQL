modeling:
  title: "Modeling auto claims"
  models:
    prob_model_name: "mod_prob_auto_indemnity"
    sev_model_name: "mod_sev_auto_indemnity"
  data:
    seed: 1818
    filter_role: "train"
    columns_to_select:
      - "TIME_CUTOFF"
      - "EXP_REPORTED_DT"
      - "DESCRIPTION_INC"
      - "DESCRIPTION_CLM"
    variable_group: "CLAIMNUMBER"
  paths:
    find_unique_vars: "funs/find_unique_vars.R"
    create_index: "funs/create_index.R"
    training_data_path: "path/to/training_data.csv"
    formula: "paid_left ~ GR_HOMEREPORTEDTYPE_TYPECODE + GR_LOSS_LOC_PROV_M + NUM_COST_CATS + REP_VEHICLEDRIVEABLE"
  training:
    num_threads: 12
    cross_validation:
      number_cv: 3
      fit_control:
        search: "grid"
        method: "cv"
        allow_parallel: true
      tune_grid:
        nrounds: [149, 150]
        max_depth: [8]
        eta: [0.035]
        gamma: [0.45]
        colsample_bytree: [0.65]
        min_child_weight: [60]
        subsample: [0.75]



library(R6)
library(yaml)
library(caret)
library(dplyr)

# Define the R6 class
AutoClaimsModel <- R6Class(
  "AutoClaimsModel",
  public = list(
    config = NULL,
    data_train = NULL,
    indexes = NULL,
    formula = NULL,
    fit_control = NULL,
    tune_grid = NULL,
    model = NULL,
    
    # Initialization
    initialize = function(config_file) {
      self$config <- yaml::read_yaml(config_file)
      set.seed(self$config$modeling$data$seed)
      message("Configuration loaded and seed set.")
    },
    
    # Prepare data
    prepare_data = function(data_baked) {
      self$data_train <- data_baked %>%
        dplyr::filter(data_role == self$config$modeling$data$filter_role) %>%
        dplyr::select(-all_of(self$config$modeling$data$columns_to_select))
      message("Data prepared. Dimensions: ", paste(dim(self$data_train), collapse = " x "))
    },
    
    # Remove single-modality variables
    remove_single_modality_vars = function() {
      source(self$config$modeling$paths$find_unique_vars)
      vars_to_delete <- find_unique_vars(self$data_train)
      self$data_train <- self$data_train %>% dplyr::select(-all_of(vars_to_delete))
      message("Single-modality variables removed.")
    },
    
    # Create indexes for cross-validation
    create_indexes = function(number_cv) {
      source(self$config$modeling$paths$create_index)
      self$indexes <- create_index(
        data_train = self$data_train,
        number_cv = number_cv,
        variable_group = self$config$modeling$data$variable_group
      )
      message("Indexes created for cross-validation.")
    },
    
    # Set formula
    set_formula = function() {
      self$formula <- as.formula(self$config$modeling$paths$formula)
      message("Formula set: ", deparse(self$formula))
    },
    
    # Set up fit control
    setup_fit_control = function(number_cv) {
      if (number_cv > 1) {
        self$fit_control <- trainControl(
          search = self$config$modeling$training$cross_validation$fit_control$search,
          method = self$config$modeling$training$cross_validation$fit_control$method,
          number = number_cv,
          index = self$indexes,
          allowParallel = self$config$modeling$training$cross_validation$fit_control$allow_parallel
        )
      } else {
        self$fit_control <- trainControl(
          search = "grid",
          method = "none"
        )
      }
      message("Fit control setup complete.")
    },
    
    # Set up tune grid
    setup_tune_grid = function() {
      self$tune_grid <- expand.grid(
        nrounds = self$config$modeling$training$cross_validation$tune_grid$nrounds,
        max_depth = self$config$modeling$training$cross_validation$tune_grid$max_depth,
        eta = self$config$modeling$training$cross_validation$tune_grid$eta,
        gamma = self$config$modeling$training$cross_validation$tune_grid$gamma,
        colsample_bytree = self$config$modeling$training$cross_validation$tune_grid$colsample_bytree,
        min_child_weight = self$config$modeling$training$cross_validation$tune_grid$min_child_weight,
        subsample = self$config$modeling$training$cross_validation$tune_grid$subsample
      )
      message("Tune grid setup complete.")
    },
    
    # Train the model
    train_model = function(number_cv) {
      self$setup_fit_control(number_cv)
      self$setup_tune_grid()
      
      tic()
      self$model <- train(
        formula = self$formula,
        data = self$data_train,
        method = "xgbTree",
        trControl = self$fit_control,
        tuneGrid = self$tune_grid,
        objective = "binary:logistic",
        nthread = self$config$modeling$training$num_threads,
        verbose = TRUE,
        print_every_n = 1
      )
      toc()
      message("Model training complete.")
    }
  )
)

# Example Usage
claims_model <- AutoClaimsModel$new("config/config.yaml")

# Step 1: Prepare data
claims_model$prepare_data(data_baked)

# Step 2: Remove single-modality variables
claims_model$remove_single_modality_vars()

# Step 3: Create indexes for cross-validation
claims_model$create_indexes(number_cv = 3)

# Step 4: Set formula
claims_model$set_formula()

# Step 5: Train the model
claims_model$train_model(number_cv = 3)




The provided R6 class is designed to support both tuning and direct training by dynamically configuring the trainControl and tuneGrid parameters based on whether you are performing cross-validation or training with fixed parameters. Here’s how it handles both scenarios:

1. Tuning (Hyperparameter Search)

When cross-validation is enabled (i.e., number_cv > 1), the class:
	•	Configures trainControl with a search strategy for hyperparameter tuning (grid or random).
	•	Uses a tuneGrid containing multiple parameter combinations for tuning.
	•	Iterates over the grid to evaluate model performance using the specified cross-validation strategy (cv).

Key Lines in the Code:

if (number_cv > 1) {
  self$fit_control <- trainControl(
    search = self$config$modeling$training$cross_validation$fit_control$search,
    method = self$config$modeling$training$cross_validation$fit_control$method,
    number = number_cv,
    index = self$indexes,
    allowParallel = self$config$modeling$training$cross_validation$fit_control$allow_parallel
  )
}

self$tune_grid <- expand.grid(
  nrounds = self$config$modeling$training$cross_validation$tune_grid$nrounds,
  max_depth = self$config$modeling$training$cross_validation$tune_grid$max_depth,
  eta = self$config$modeling$training$cross_validation$tune_grid$eta,
  gamma = self$config$modeling$training$cross_validation$tune_grid$gamma,
  colsample_bytree = self$config$modeling$training$cross_validation$tune_grid$colsample_bytree,
  min_child_weight = self$config$modeling$training$cross_validation$tune_grid$min_child_weight,
  subsample = self$config$modeling$training$cross_validation$tune_grid$subsample
)

When train is called:
	•	The model is evaluated on each combination in the tuneGrid using the fit_control cross-validation strategy.
	•	The best hyperparameters are selected automatically.

2. Direct Training (Without Tuning)

When cross-validation is disabled (i.e., number_cv == 1), the class:
	•	Configures trainControl for training with a single set of parameters without hyperparameter search:
	•	The method is set to none, meaning no resampling or parameter search will occur.
	•	Bypasses the need for a tuneGrid, allowing direct training with the default or specified parameters.

Key Lines in the Code:

if (number_cv <= 1) {
  self$fit_control <- trainControl(
    search = "grid",
    method = "none"
  )
}

When train is called:
	•	The model is trained on the entire dataset with a fixed configuration.

Dynamic Support for Both Scenarios

The behavior of the class adapts based on the number_cv parameter:
	•	If number_cv > 1, the model performs tuning with cross-validation.
	•	If number_cv == 1, the model skips tuning and performs direct training with fixed parameters.

This is seamless because the setup for trainControl and tuneGrid is encapsulated in the methods setup_fit_control and setup_tune_grid.

Usage Examples

Tuning

To perform cross-validation and tune hyperparameters:

claims_model$train_model(number_cv = 3)

Direct Training

To skip tuning and train with fixed parameters:

claims_model$train_model(number_cv = 1)

Why This Is Flexible

	1.	Single Method for Both: The same train_model method supports both scenarios, reducing duplication.
	2.	Parameter Customization: The config.yaml file provides full control over the tuning grid and training behavior, enabling flexibility without modifying the R6 class.
	3.	Streamlined Workflow: Users can switch between tuning and direct training simply by adjusting number_cv.

