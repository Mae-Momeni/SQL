# Fix new levels for a specific column
column_to_fix <- "GR_INTC_RISK_PROVINCE_CODE"

# Get the most frequent level from training data
most_frequent_level <- data_train_sev %>%
  count(!!sym(column_to_fix), sort = TRUE) %>%
  slice(1) %>%
  pull(!!sym(column_to_fix))

# Replace new levels in test data
data_test[[column_to_fix]] <- as.character(data_test[[column_to_fix]])
data_test[[column_to_fix]] <- ifelse(
  data_test[[column_to_fix]] %in% unique(data_train_sev[[column_to_fix]]),
  data_test[[column_to_fix]],
  most_frequent_level
)