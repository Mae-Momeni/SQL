create_index <- function(data_train, number_cv, variable_group) {
  set.seed(123) # Ensure reproducibility
  
  # Step 1: Group by variable_group and assign folds
  claims_indexes <- data_train %>%
    group_by(across(all_of(variable_group))) %>%
    summarise(index = sample(1:number_cv, 1, replace = TRUE), .groups = "drop") 
  
  # Step 2: Merge indices with data_train
  data_train <- data_train %>%
    left_join(claims_indexes, by = variable_group) %>%
    mutate(rownum = row_number()) # Add rownum
  
  # Step 3: Extract row numbers for each fold
  indexes <- lapply(1:number_cv, function(i) {
    data_train %>% 
      filter(index == i) %>% 
      pull(rownum)
  })
  
  return(indexes)
}