library(dplyr)

# Extract validation rows for each Resample
oof_valid_predictions <- mod_prob_auto_indemnity$pred %>%
  rowwise() %>%
  filter(!(rowIndex %in% unlist(indexes[[Resample]]))) %>%  # Exclude training indices
  ungroup() %>%
  distinct(rowIndex, Resample, .keep_all = TRUE)            # Deduplicate rows

# Verify validation set sizes per fold
valid_set_summary <- oof_valid_predictions %>%
  group_by(Resample) %>%
  summarise(valid_set_size = n())

# Print results
print(valid_set_summary)       # Validation set sizes
print(oof_valid_predictions)   # Final filtered validation rows