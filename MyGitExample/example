library(dplyr)

# Define validation percentage (e.g., 25%)
validation_percentage <- 0.25

# Dynamically extract validation rows
oof_valid_predictions <- mod_prob_auto_indemnity$pred %>%
  group_by(Resample) %>%
  slice(1:floor(n() * validation_percentage)) %>%  # Take first 25% of rows dynamically
  ungroup()

# Verify the size of the validation set for each Resample
valid_set_summary <- oof_valid_predictions %>%
  group_by(Resample) %>%
  summarise(valid_set_size = n())

# Print validation set sizes and the validation predictions
print(valid_set_summary)
print(oof_valid_predictions)