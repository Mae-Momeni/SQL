library(dplyr)

# Extract OOF predictions for each fold
oof_valid_predictions <- mod_prob_auto_indemnity$pred %>%
  group_by(Resample) %>%                        # Group by fold (Resample)
  filter(!rowIndex %in% rowIndex[Resample != unique(Resample)]) %>% # Keep only validation rows
  ungroup()

# Verify results: Count validation rows per fold
oof_valid_summary <- oof_valid_predictions %>%
  group_by(Resample) %>%
  summarise(valid_set_size = n_distinct(rowIndex))

# Display OOF predictions and summary
print(oof_valid_predictions)
print(oof_valid_summary)