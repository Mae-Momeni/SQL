Here is the unified function for extracting data from different server paths, based on a server_key parameter. I also include how you can update your YAML configuration file to store the server paths.

Unified Function

extract_workzone_table <- function(table_name, server_key, config_file = "config/config.yaml") {
  # Load configuration
  config <- yaml::read_yaml(config_file)
  
  # Retrieve the server path based on the server key
  server_path <- config$server_paths[[server_key]]
  
  if (is.null(server_path)) {
    stop(glue::glue("Invalid server_key: {server_key}. Check the config file."))
  }
  
  # Create the pool
  pool <- pool::dbPool(
    drv = odbc::odbc(),
    driver = server_path$driver,
    database = server_path$database,
    uid = Sys.getenv(server_path$uid_env),
    pwd = Sys.getenv(server_path$pwd_env),
    server = server_path$server,
    Authentication = server_path$authentication,
    port = server_path$port,
    idleTimeout = server_path$idleTimeout,
    encoding = server_path$encoding,
    encrypt = server_path$encrypt
  )
  
  # Extract the dataset
  db_data <- dbGetQuery(pool, glue::glue("SELECT * FROM WZ_CLAIMS.{table_name};")) %>%
    clean_names(case = "snake")
  
  # Close the pool
  pool::poolClose(pool)
  
  message(glue::glue("Data extracted from {server_key} for table {table_name}."))
  return(db_data)
}

