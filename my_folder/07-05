Step 2: Simplified R6 Class

This is a streamlined version of the R6 class focusing on simplicity and readability while keeping it functional.

library(R6)
library(yaml)
library(dplyr)

# Define the R6 class
AutoClaimsModel <- R6Class(
  "AutoClaimsModel",
  public = list(
    config = NULL,
    data_train = NULL,
    indexes = NULL,

    # Initialization: load configuration file
    initialize = function(config_file) {
      self$config <- yaml::read_yaml(config_file)
      set.seed(self$config$modeling$data$seed)
      message("Configuration loaded and seed set.")
    },

    # Step 1: Filter and select relevant columns from data
    prepare_data = function(data_baked) {
      self$data_train <- data_baked %>%
        filter(data_role == self$config$data$filter_role) %>%
        select(all_of(self$config$data$columns_to_select)) %>%
        filter(model_prob == self$config$modeling$models$prob_model_name)
      message("Data prepared. Dimensions: ", paste(dim(self$data_train), collapse = " x "))
    },

    # Step 2: Remove single-modality variables
    remove_single_modality_vars = function() {
      source(self$config$paths$find_unique_vars)
      vars_to_delete <- find_unique_vars(self$data_train)
      self$data_train <- self$data_train %>%
        select(-all_of(vars_to_delete))
      message("Single-modality variables removed.")
    },

    # Step 3: Preprocess data
    preprocess_data = function() {
      self$data_train <- self$data_train %>%
        mutate(paid_left = ifelse(AMT_LEFT_TO_PAY > 0, "Yes payment", "No payment")) %>%
        filter(!is.na(paid_left))
      message("Data preprocessing complete.")
    },

    # Step 4: Create indexes
    create_indexes = function(number_cv) {
      source(self$config$paths$create_index)
      self$indexes <- create_index(
        self$data_train,
        number_cv = number_cv,
        variable_group = self$config$data$variable_group
      )
      message("Indexes created for cross-validation.")
    }
  )
)

Step 3: Usage Example

Here’s how you can use the class step-by-step.

# Load required libraries
library(dplyr)

# Example: Load your dataset (replace with actual data loading logic)
data_baked <- <your_data_loading_logic_here>

# Step 1: Initialize the model with the config file
claims_model <- AutoClaimsModel$new("config/config.yaml")

# Step 2: Prepare data
claims_model$prepare_data(data_baked)

# Step 3: Remove single-modality variables
claims_model$remove_single_modality_vars()

# Step 4: Preprocess the data
claims_model$preprocess_data()

# Step 5: Create indexes for cross-validation
claims_model$create_indexes(number_cv = 5)

# Access processed data and indexes
processed_data <- claims_model$data_train
indexes <- claims_model$indexes

