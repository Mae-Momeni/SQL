library(dplyr)

# Extract only the OOF predictions for validation rows
oof_valid_predictions <- mod_prob_auto_indemnity$pred %>%
  group_by(Resample) %>%
  filter(rowIndex %in% rowIndex[Resample == unique(Resample)]) %>%
  distinct(rowIndex, .keep_all = TRUE) %>%
  ungroup()

# Verify the size of the validation set for each fold
valid_set_summary <- oof_valid_predictions %>%
  group_by(Resample) %>%
  summarise(valid_set_size = n_distinct(rowIndex))

# Print validation set summary
print(valid_set_summary)

# Print OOF predictions
print(oof_valid_predictions)