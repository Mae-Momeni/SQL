library(R6)
library(yaml)
library(xgboost)

AutoClaimsModel <- R6Class(
  "AutoClaimsModel",
  public = list(
    config = NULL,
    data_train = NULL,
    indexes = NULL,
    fit_control = NULL,
    tune_grid = NULL,
    model = NULL,
    
    initialize = function(config_file) {
      self$config <- yaml::read_yaml(config_file)
      set.seed(self$config$modeling$data$seed)
      message("Configuration loaded and seed set.")
    },
    
    prepare_data = function(data_baked) {
      self$data_train <- data_baked %>%
        dplyr::filter(data_role == self$config$modeling$data$filter_role) %>%
        dplyr::select(-all_of(self$config$modeling$data$columns_to_select)) %>%
        dplyr::filter(model_prob == self$config$modeling$models$prob_model_name)
      
      message("Data prepared. Dimensions: ", paste(dim(self$data_train), collapse = " x "))
    },
    
    remove_single_modality_vars = function() {
      source(self$config$modeling$paths$find_unique_vars)
      vars_to_delete <- find_unique_vars(self$data_train)
      self$data_train <- self$data_train %>%
        dplyr::select(-all_of(vars_to_delete))
      message("Single-modality variables removed.")
    },
    
    preprocess_data = function() {
      self$data_train <- self$data_train %>%
        dplyr::mutate(paid_left = ifelse(AMT_LEFT_TO_PAY > 0, "Yes payment", "No payment")) %>%
        dplyr::filter(!is.na(paid_left))
      message("Data preprocessing complete.")
    },
    
    create_indexes = function(number_cv) {
      source(self$config$modeling$paths$create_index)
      self$indexes <- create_index(
        data_train = self$data_train,
        number_cv = number_cv,
        variable_group = self$config$modeling$data$variable_group
      )
      message("Indexes created for cross-validation.")
    },
    
    set_formula = function() {
      self$formula <- as.formula(self$config$modeling$formula)
      message("Formula set: ", deparse(self$formula))
    },
    
    validate_formula = function() {
      all_vars <- all.vars(as.formula(self$formula))
      extra_vars <- setdiff(all_vars, colnames(self$data_train))
      if (length(extra_vars) > 0) {
        for (var in extra_vars) {
          self$formula <- stats::update(self$formula, paste0(". ~ . - ", var))
          message("Removed variable: ", var, " from the formula.")
        }
      }
      message("Validated formula: ", deparse(self$formula))
    },
    
    setup_fit_control = function(number_cv) {
      if (number_cv > 1) {
        self$fit_control <- trainControl(
          search = self$config$modeling$training$cross_validation$fit_control$search,
          method = self$config$modeling$training$cross_validation$fit_control$method,
          number = number_cv,
          index = self$indexes,
          allowParallel = self$config$modeling$training$cross_validation$fit_control$allow_parallel
        )
      } else {
        self$fit_control <- trainControl(
          search = "grid",
          method = "none"
        )
      }
      message("Fit control setup complete.")
    },
    
    setup_tune_grid = function() {
      self$tune_grid <- expand.grid(
        nrounds = self$config$modeling$training$cross_validation$tune_grid$nrounds,
        max_depth = self$config$modeling$training$cross_validation$tune_grid$max_depth,
        eta = self$config$modeling$training$cross_validation$tune_grid$eta,
        gamma = self$config$modeling$training$cross_validation$tune_grid$gamma,
        colsample_bytree = self$config$modeling$training$cross_validation$tune_grid$colsample_bytree,
        min_child_weight = self$config$modeling$training$cross_validation$tune_grid$min_child_weight,
        subsample = self$config$modeling$training$cross_validation$tune_grid$subsample
      )
      message("Tune grid setup complete.")
    },
    
    train_model = function(number_cv) {
      self$setup_fit_control(number_cv)
      self$setup_tune_grid()
      tic()
      self$model <- train(
        formula = self$formula,
        data = self$data_train,
        method = "xgbTree",
        trControl = self$fit_control,
        tuneGrid = self$tune_grid,
        objective = "binary:logistic",
        nthread = self$config$modeling$training$num_threads,
        verbose = TRUE,
        print_every_n = 1
      )
      toc()
      message("Model training complete.")
    }
  )
)



modeling:
  title: "Modeling auto claims"
  models:
    prob_model_name: "mod_prob_auto_indemnity"
    sev_model_name: "mod_sev_auto_indemnity"
  data:
    seed: 1818
    filter_role: "train"
    columns_to_select:
      - TIME_CUTOFF
      - EXP_REPORTED_DT
      - DESCRIPTION_INC
      - DESCRIPTION_CLM
      - CASERES
    variable_group: "CLAIMNUMBER"
  paths:
    find_unique_vars: "funs/find_unique_vars.R"
    create_index: "funs/create_index.R"
    training_data_path: "path/to/training_data.csv"
  formula: "paid_left ~ lossmonth + GR_HOWREPORTEDTYPE_TYPECODE + GR_LOSS_LOC_PROV_M + GR_LOSSKIND_TYPECODE"
  training:
    num_threads: 12
    cross_validation:
      number_cv: 3
      fit_control:
        search: "grid"
        method: "cv"
        allow_parallel: true
      tune_grid:
        nrounds: [149, 150]
        max_depth: [8]
        eta: [0.035]
        gamma: [0.45]
        colsample_bytree: [0.65]
        min_child_weight: [60]
        subsample: [0.75]


How to Train with Default Parameters?

To train with default parameters:
	1.	Comment out the tune_grid section in the YAML file.
	2.	The setup_tune_grid() function will not override the default parameters of the train method.





