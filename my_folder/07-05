# Assuming 'mod' is your trained model and 'mod$trainingData' is the training data used

# 1. Prepare the explainer using lime
explainer <- lime(
  select(mod$trainingData, -.outcome),  # Select all features except the outcome variable
  mod,                                  # The model object
  bin_continuous = TRUE                 # Bin continuous variables for better interpretation
)

# 2. Generate an explanation for a sample of the data
explanation <- explain(
  sample_n(mod$trainingData, 1) %>% select(-.outcome), # Take a sample of one instance from the data
  explainer,
  n_features = 10  # Number of top features to display
)

# 3. Plot the feature importance using the explanation from LIME
plot_features(explanation, ncol = 1) -> g

# 4. Print the plot
print(g)