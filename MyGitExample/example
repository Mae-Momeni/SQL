# Initialize an empty list to store valid set predictions
oof_valid_predictions <- list()

# Loop through each fold (resample)
for (i in 1:number_cv) {
  # Get row indices for the current fold's validation set
  valid_indices <- valid_rows[[i]]
  
  # Filter predictions for the current Resample and matching row indices
  fold_valid_preds <- mod_prob_auto_indemnity$pred %>%
    filter(Resample == paste0("Resample", i) & rowIndex %in% valid_indices)
  
  # Store in the list
  oof_valid_predictions[[i]] <- fold_valid_preds
}

# Combine all valid set predictions into one data frame
oof_valid_predictions_final <- bind_rows(oof_valid_predictions)

# View the OOF validation predictions
print(oof_valid_predictions_final)